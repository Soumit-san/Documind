{
  "manifest_version": 3,
  "name": "DocuMind AI",
  "version": "0.1.0",
  "description": "Intelligent Document Assistant — AI-powered summarization and Q&A for any document in your browser.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "DocuMind AI — Click to open sidebar"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+D"
      },
      "description": "Toggle DocuMind AI sidebar"
    }
  }
}
